# -------------------------------------------------------
# Court Simulation Sandbox — Environment Configuration
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Application environment: development | staging | production
NODE_ENV=development

# Server port for the web UI
PORT=3000

# PostgreSQL connection string for session persistence
DATABASE_URL=postgresql://localhost:5432/court_sandbox

# --- AI Provider Configuration ---

# Anthropic API key (used for Claude-powered actors)
ANTHROPIC_API_KEY=your-anthropic-key

# OpenAI API key (alternative provider)
OPENAI_API_KEY=your-openai-key

# Which AI provider to use by default: anthropic | openai
DEFAULT_AI_PROVIDER=anthropic

# --- Simulation Settings ---

# Default AI difficulty: beginner | intermediate | advanced | expert
AI_DIFFICULTY=medium

# Maximum number of dialogue turns per session
MAX_TURNS_PER_SESSION=50

# Session timeout in minutes (auto-end inactive sessions)
SESSION_TIMEOUT_MINUTES=60
